# Datenbankzugangsdaten (all-inkl.com)
# Diese Datei als ".env" kopieren und mit echten Werten füllen.
# Die .env-Datei NIEMALS ins Git committen!

DB_HOST=localhost
DB_NAME=deinedatenbank
DB_USER=deinusername
DB_PASS=deinpasswort

# Basis-URL der Website (kein trailing slash!)
BASE_URL=https://teil-es.de

# Geheimes Token für setup.php (z. B. 32 zufällige Zeichen)
# Aufruf: https://teil-es.de/admin/setup.php?token=DEIN_TOKEN
# Nach dem Setup: diese Zeile löschen oder leer lassen → setup.php gibt dann 404 zurück
SETUP_TOKEN=
