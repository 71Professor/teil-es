# QR Code Manager – URL Rewriting für teil-es.de (Root-Installation)

RewriteEngine On
RewriteBase /

# HTTPS erzwingen
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# .env niemals direkt ausliefern
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Admin-Bereich und existierende Dateien/Ordner nicht umschreiben
RewriteCond %{REQUEST_URI} !^/admin/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# /SHORTCODE → redirect.php?code=SHORTCODE
RewriteRule ^([a-zA-Z0-9_-]+)$ redirect.php?code=$1 [L,QSA]
